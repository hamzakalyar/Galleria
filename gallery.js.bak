"use strict";

const SECTIONS = [
  { id: "floor",    label: "Floor"    },
  { id: "stairs",   label: "Stairs"   },
  { id: "roof",     label: "Roof"     },
  { id: "washroom", label: "Washroom" },
  { id: "kitchen",  label: "Kitchen"  },
];

let allImages = [];
let lbIndex   = 0;

const galleryRoot  = document.getElementById("gallery-root");
const lightbox     = document.getElementById("lightbox");
const lbImg        = document.getElementById("lbImg");
const lbCounter    = document.getElementById("lbCounter");
const lbClose      = document.getElementById("lbClose");
const lbPrev       = document.getElementById("lbPrev");
const lbNext       = document.getElementById("lbNext");
const heroBgImg    = document.getElementById("heroBgImg");
const navbar       = document.getElementById("navbar");
const footerYear   = document.getElementById("footerYear");

function encode(name) {
  return name.split("/").map(encodeURIComponent).join("/");
}

/* Pick a random hero image from whichever section has the nicest-looking
   photos — prefer floor or kitchen (more likely to have wide scenic shots) */
function setHeroImage(manifest) {
  const preferred = ["floor", "kitchen", "washroom", "stairs", "roof"];
  for (const id of preferred) {
    const files = manifest[id];
    if (files && files.length > 0) {
      const pick = files[Math.floor(Math.random() * files.length)];
      heroBgImg.src = id + "/" + encode(pick);
      heroBgImg.addEventListener("load",  () => heroBgImg.classList.add("loaded"));
      heroBgImg.addEventListener("error", () => {
        /* fallback: try first image of first section */
        for (const sec of SECTIONS) {
          const f = manifest[sec.id];
          if (f && f.length > 0) { heroBgImg.src = sec.id + "/" + encode(f[0]); break; }
        }
      });
      break;
    }
  }
}

async function buildGallery() {
  let manifest;
  try {
    const res = await fetch("manifest.json");
    if (!res.ok) throw new Error("HTTP " + res.status);
    manifest = await res.json();
  } catch (err) {
    galleryRoot.innerHTML = `<p style="padding:60px 40px;color:#aaa;font-size:.9rem;">
      Could not load manifest.json. Run <code>node generate-manifest.js</code> first.
    </p>`;
    return;
  }

  setHeroImage(manifest);
  galleryRoot.innerHTML = "";
  allImages = [];

  for (const sec of SECTIONS) {
    const files = manifest[sec.id] || [];

    const section = document.createElement("section");
    section.className = "gallery-section";
    section.id = "section-" + sec.id;

    section.innerHTML = `
      <div class="section-header">
        <h2 class="section-title">${sec.label}</h2>
        <span class="section-count">${files.length} photo${files.length !== 1 ? "s" : ""}</span>
      </div>
      <div class="img-grid" id="grid-${sec.id}"></div>
    `;
    galleryRoot.appendChild(section);

    const grid = section.querySelector(".img-grid");
    if (files.length === 0) {
      grid.innerHTML = `<p style="color:#bbb;font-size:.85rem;padding:4px 0">No images found.</p>`;
      continue;
    }

    files.forEach((filename) => {
      const idx = allImages.length;
      const src = sec.id + "/" + encode(filename);
      allImages.push({ src, filename });

      const card = document.createElement("div");
      card.className = "img-card";

      const img = document.createElement("img");
      img.alt      = filename;
      img.loading  = "lazy";
      img.decoding = "async";
      img.addEventListener("load",  () => { img.classList.add("loaded"); card.classList.add("has-image"); });
      img.addEventListener("error", () => { card.classList.add("has-image"); card.style.background = "#eee"; });
      img.src = src;

      card.appendChild(img);
      card.addEventListener("click", () => openLightbox(idx));
      grid.appendChild(card);
    });
  }
}

/* ── Lightbox ── */
function openLightbox(idx) {
  lbIndex = idx;
  renderLb();
  lightbox.classList.add("open");
  document.body.style.overflow = "hidden";
}
function closeLightbox() {
  lightbox.classList.remove("open");
  document.body.style.overflow = "";
}
function renderLb(dir) {
  const e = allImages[lbIndex];
  if (!e) return;
  if (dir !== undefined) {
    lbImg.classList.add("fading");
    setTimeout(() => {
      lbImg.src = e.src; lbImg.alt = e.filename;
      lbCounter.textContent = (lbIndex + 1) + " / " + allImages.length;
      lbImg.classList.remove("fading");
    }, 180);
  } else {
    lbImg.src = e.src; lbImg.alt = e.filename;
    lbCounter.textContent = (lbIndex + 1) + " / " + allImages.length;
  }
}
function lbGo(dir) { lbIndex = (lbIndex + dir + allImages.length) % allImages.length; renderLb(dir); }

lbClose.addEventListener("click", closeLightbox);
lbPrev.addEventListener("click",  () => lbGo(-1));
lbNext.addEventListener("click",  () => lbGo(1));
lightbox.addEventListener("click", (e) => { if (e.target === lightbox) closeLightbox(); });
document.addEventListener("keydown", (e) => {
  if (!lightbox.classList.contains("open")) return;
  if (e.key === "Escape")     closeLightbox();
  if (e.key === "ArrowLeft")  lbGo(-1);
  if (e.key === "ArrowRight") lbGo(1);
});

/* Touch swipe */
let tx = 0;
lightbox.addEventListener("touchstart", e => { tx = e.changedTouches[0].clientX; }, { passive: true });
lightbox.addEventListener("touchend",   e => {
  const d = e.changedTouches[0].clientX - tx;
  if (Math.abs(d) > 50) lbGo(d < 0 ? 1 : -1);
}, { passive: true });

/* Navbar shadow on scroll */
window.addEventListener("scroll", () => {
  navbar.classList.toggle("scrolled", window.scrollY > 20);
}, { passive: true });

footerYear.textContent = new Date().getFullYear();
buildGallery();
